{
  "name": "mrc-integrated-frontend",
  "version": "0.2.1",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite\" \"tsc -p electron/tsconfig.json --watch\" \"wait-on tcp:5173 && electron .\"",
    "build": "vue-tsc --noEmit && vite build && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json",
    "dist:win:x64": "python3 ../scripts/prepare_windows_runtime.py && npm run build && electron-builder --win portable --x64",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "lucide-vue-next": "^0.468.0",
    "vite": "^5.4.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "concurrently": "^9.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.5.0",
    "vue-tsc": "^2.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.mrc.integrated-acquisition",
    "productName": "MRC Integrated Acquisition",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "mrc_backend/**/*.py"
        ]
      },
      {
        "from": "../vendor/camera/win32",
        "to": "vendor/camera/win32",
        "filter": [
          "**/*.dll"
        ]
      },
      {
        "from": "../vendor/daq/x86",
        "to": "vendor/daq/x86",
        "filter": [
          "**/*.dll"
        ]
      },
      {
        "from": "../vendor/ffmpeg/windows",
        "to": "vendor/ffmpeg/windows"
      },
      {
        "from": "../scripts/ensure_backend_port_windows.ps1",
        "to": "scripts/ensure_backend_port_windows.ps1"
      },
      {
        "from": "build/python-win32",
        "to": "python"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MRC-Integrated-Acquisition-${version}-Windows-x64.${ext}"
    }
  }
}
