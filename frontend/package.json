{
  "name": "mrc-integrated-frontend",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite\" \"tsc -p electron/tsconfig.json --watch\" \"wait-on tcp:5173 && electron .\"",
    "build": "vue-tsc --noEmit && vite build && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "electron": "^31.0.0",
    "lucide-vue-next": "^0.468.0",
    "vite": "^5.4.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.5.0",
    "vue-tsc": "^2.0.0",
    "wait-on": "^7.2.0"
  }
}

